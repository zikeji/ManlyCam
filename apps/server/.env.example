# ManlyCam Server — Environment Variables
# Copy this to .env and fill in your values.

# HTTP server port
PORT=3000

# Public base URL of this server (used for OAuth redirect construction, etc.)
BASE_URL=http://localhost:3000

# PostgreSQL connection string (must use TIMESTAMPTZ columns — always)
DATABASE_URL=postgresql://user:password@localhost:5432/manlycam

# Secret used to sign/encrypt sessions (min 32 chars recommended)
SESSION_SECRET=change-me-to-a-long-random-secret

# Google OAuth 2.0 credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Path where HLS segments are written by the transcoding pipeline
HLS_SEGMENT_PATH=/tmp/manlycam/hls

# FRP (fast reverse proxy) ports
FRP_STREAM_PORT=7000
FRP_API_PORT=7400

# Secret API key used by the Pi agent to authenticate with the server
AGENT_API_KEY=change-me-to-a-random-secret

# Human-readable name for the camera subject (e.g. "Manly")
PET_NAME=Manly

# Display name for the site (shown in UI and page titles)
SITE_NAME=ManlyCam
