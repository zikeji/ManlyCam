# ManlyCam Server — Environment Variables
# Copy this to .env and fill in your values.
# NOTE: These are local development defaults. For production, adjust accordingly.

# HTTP server port
PORT=3000

# Public base URL of this application
# NOTE: With Vite dev server, this must be the Vite dev server URL, not the backend
# For development with Vite: http://localhost:5173
# For development without Vite: http://localhost:3000
# For production: https://yourdomain.com
BASE_URL=http://localhost:5173

# Site domain (required for Traefik and Caddyfile deployments)
# Used in: apps/server/deploy/traefik/docker-compose.yml, apps/server/deploy/Caddyfile
# Example: cam.example.com (without https://)
SITE_DOMAIN=localhost

# PostgreSQL connection string (must use TIMESTAMPTZ columns — always)
DATABASE_URL=postgresql://user:password@localhost:5432/manlycam

# Postgres password (used in docker-compose deployments)
POSTGRES_PASSWORD=change-me-to-a-random-secret

# Secret used to sign/encrypt sessions (min 32 chars recommended)
SESSION_SECRET=change-me-to-a-long-random-secret

# Google OAuth 2.0 credentials
# Redirect URI is constructed as: ${BASE_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# FRP (fast reverse proxy) host and ports
# FRP_HOST is the hostname of the frps server:
#   - Docker deployments: set to "frps" (the Docker service name resolved by Docker DNS)
#   - Bare-metal / local dev: defaults to "localhost" (omit or set explicitly)
# FRP_RTSP_PORT: the frps remote_port the Pi's mediamtx RTSP tunnel is exposed on
FRP_HOST=localhost
FRP_RTSP_PORT=11935
FRP_API_PORT=11936

# PiSugar battery monitor (optional)
# If set, the server opens a TCP connection to localhost:FRP_PISUGAR_PORT to poll the PiSugar manager
# via an frpc TCP tunnel. The Pi's frpc.toml must expose PiSugar manager port 8423.
# When configured, battery status is shown in the Broadcast Console left flank (admin-only).
# Example: FRP_PISUGAR_PORT=8424
# FRP_PISUGAR_PORT=

# mediamtx base URLs (mediamtx runs as a separate service, not spawned by the server)
# Local dev defaults point to localhost; Docker Compose overrides these to http://mediamtx:PORT
# MTX_API_URL:    mediamtx HTTP API base URL (used for Pi reachability polling)
# MTX_WEBRTC_URL: mediamtx WebRTC WHEP base URL (Hono proxies WHEP signaling through here)
MTX_API_URL=http://127.0.0.1:9997
MTX_WEBRTC_URL=http://127.0.0.1:8888

# Human-readable name for the camera subject (e.g. "Manly")
PET_NAME=Manly

# Display name for the site (shown in UI and page titles)
SITE_NAME=ManlyCam

# ACME email for Let's Encrypt (required for Traefik and Caddyfile)
# Let's Encrypt sends certificate expiry notices to this address
ACME_EMAIL=admin@example.com
